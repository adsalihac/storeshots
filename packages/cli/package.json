{
  "name": "storeshots",
  "version": "0.1.0",
  "description": "Generate App Store and Play Store screenshots from Expo Router apps.",
  "type": "module",
  "bin": {
    "storeshots": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@storeshots/core": "workspace:*",
    "@storeshots/device-presets": "workspace:*",
    "@storeshots/shared": "workspace:*",
    "commander": "^12.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
