{
  "name": "@storeshots/core",
  "version": "0.1.0",
  "description": "Core Storeshots screenshot generation pipeline.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@storeshots/device-presets": "workspace:*",
    "@storeshots/expo-router-discovery": "workspace:*",
    "@storeshots/image-processor": "workspace:*",
    "@storeshots/screenshot-engine": "workspace:*",
    "@storeshots/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
