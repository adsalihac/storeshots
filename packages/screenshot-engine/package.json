{
  "name": "@storeshots/screenshot-engine",
  "version": "0.1.0",
  "description": "Screenshot capture orchestration for Storeshots.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@storeshots/shared": "workspace:*",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
